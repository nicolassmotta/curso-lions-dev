# Porta usada no computador local.
PORT=3000

# Connection string do MongoDB Atlas.
MONGO_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/lionsbank

# Chave usada para assinar e verificar tokens JWT.
JWT_SECRET=troque_essa_chave_por_uma_chave_grande
JWT_EXPIRES_IN=1d

# Custo usado pelo bcrypt para senha de usuário e senha de cartão.
BCRYPT_SALT_ROUNDS=10

# Limite diário de PIX. 500000 = R$ 5.000,00.
LIMITE_PIX_DIARIO_CENTAVOS=500000
