# Testes da API LionsBank usando a extensão REST Client do VS Code.

@baseUrl = http://localhost:3000

# Preencha depois de fazer login.
@tokenCliente = cole_o_token_cliente_aqui
@tokenAdmin = cole_o_token_admin_aqui

# Preencha com IDs retornados pela API.
@contaClienteId = cole_o_id_da_conta_cliente_aqui
@contaDestinoId = cole_o_id_da_conta_destino_aqui
@transacaoId = cole_o_id_da_transacao_aqui
@boletoId = cole_o_id_do_boleto_aqui
@cartaoId = cole_o_id_do_cartao_aqui
@emprestimoId = cole_o_id_do_emprestimo_aqui

### Rota inicial
GET {{baseUrl}}/

### Cadastrar cliente
POST {{baseUrl}}/api/auth/cadastro
Content-Type: application/json

{
  "nome": "Maria Silva",
  "email": "maria@email.com",
  "cpf": "11122233344",
  "telefone": "11988887777",
  "senha": "123456"
}

### Login cliente
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "maria@email.com",
  "senha": "123456"
}

### Login admin
# Cadastre um usuario e altere o papel dele para "admin" no MongoDB Compass.
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "admin@email.com",
  "senha": "123456"
}

### Perfil
GET {{baseUrl}}/api/usuarios/perfil
Authorization: Bearer {{tokenCliente}}

### Solicitar conta corrente
POST {{baseUrl}}/api/contas
Content-Type: application/json
Authorization: Bearer {{tokenCliente}}

{
  "tipo": "corrente",
  "limiteChequeEspecialCentavos": 100000
}

### Aprovar conta
PATCH {{baseUrl}}/api/contas/{{contaClienteId}}/status
Content-Type: application/json
Authorization: Bearer {{tokenAdmin}}

{
  "status": "ativa"
}

### Minhas contas
GET {{baseUrl}}/api/contas/minhas
Authorization: Bearer {{tokenCliente}}

### Depositar
POST {{baseUrl}}/api/transacoes/deposito
Content-Type: application/json
Authorization: Bearer {{tokenCliente}}

{
  "contaId": "{{contaClienteId}}",
  "valorCentavos": 200000,
  "descricao": "Depósito inicial"
}

### Sacar
POST {{baseUrl}}/api/transacoes/saque
Content-Type: application/json
Authorization: Bearer {{tokenCliente}}

{
  "contaId": "{{contaClienteId}}",
  "valorCentavos": 5000
}

### Transferir
POST {{baseUrl}}/api/transacoes/transferencia
Content-Type: application/json
Authorization: Bearer {{tokenCliente}}

{
  "contaOrigemId": "{{contaClienteId}}",
  "contaDestinoId": "{{contaDestinoId}}",
  "valorCentavos": 600000,
  "descricao": "Transferência de teste"
}

### Extrato
GET {{baseUrl}}/api/contas/{{contaClienteId}}/extrato
Authorization: Bearer {{tokenCliente}}

### Aprovar transferência pendente
# Use o ID de uma transferência acima de R$ 5.000,00.
PATCH {{baseUrl}}/api/transacoes/{{transacaoId}}/aprovar
Authorization: Bearer {{tokenAdmin}}

### Recusar transferência pendente
# Use o ID de uma transferência acima de R$ 5.000,00.
PATCH {{baseUrl}}/api/transacoes/{{transacaoId}}/recusar
Content-Type: application/json
Authorization: Bearer {{tokenAdmin}}

{
  "motivo": "Movimentação fora do perfil esperado."
}

### Cadastrar chave PIX
POST {{baseUrl}}/api/pix/chaves
Content-Type: application/json
Authorization: Bearer {{tokenCliente}}

{
  "contaId": "{{contaClienteId}}",
  "tipo": "email"
}

### Listar chaves PIX
GET {{baseUrl}}/api/pix/chaves
Authorization: Bearer {{tokenCliente}}

### Consultar limites PIX
GET {{baseUrl}}/api/pix/limites
Authorization: Bearer {{tokenCliente}}

### Enviar PIX
POST {{baseUrl}}/api/pix/enviar
Content-Type: application/json
Authorization: Bearer {{tokenCliente}}

{
  "contaOrigemId": "{{contaClienteId}}",
  "chavePix": "destino@email.com",
  "valorCentavos": 5000
}

### Gerar boleto
POST {{baseUrl}}/api/boletos
Content-Type: application/json
Authorization: Bearer {{tokenCliente}}

{
  "contaId": "{{contaClienteId}}",
  "beneficiario": "Lions Energia",
  "valorCentavos": 7500,
  "dataVencimento": "2026-07-10"
}

### Pagar boleto
POST {{baseUrl}}/api/boletos/{{boletoId}}/pagar
Content-Type: application/json
Authorization: Bearer {{tokenCliente}}

{
  "contaId": "{{contaClienteId}}"
}

### Solicitar cartão de crédito
POST {{baseUrl}}/api/cartoes
Content-Type: application/json
Authorization: Bearer {{tokenCliente}}

{
  "contaId": "{{contaClienteId}}",
  "tipo": "credito",
  "senhaCartao": "1234",
  "limiteCentavos": 100000
}

### Aprovar cartão
PATCH {{baseUrl}}/api/cartoes/{{cartaoId}}/status
Content-Type: application/json
Authorization: Bearer {{tokenAdmin}}

{
  "status": "ativo"
}

### Registrar compra no crédito
POST {{baseUrl}}/api/cartoes/{{cartaoId}}/compras
Content-Type: application/json
Authorization: Bearer {{tokenCliente}}

{
  "valorCentavos": 2500,
  "estabelecimento": "Livraria Lions",
  "descricao": "Livro de Node.js",
  "senhaCartao": "1234"
}

### Consultar fatura
GET {{baseUrl}}/api/cartoes/{{cartaoId}}/fatura
Authorization: Bearer {{tokenCliente}}

### Pagar fatura
POST {{baseUrl}}/api/cartoes/{{cartaoId}}/fatura/pagar
Content-Type: application/json
Authorization: Bearer {{tokenCliente}}

{
  "contaId": "{{contaClienteId}}"
}

### Simular empréstimo
POST {{baseUrl}}/api/emprestimos/simular
Content-Type: application/json
Authorization: Bearer {{tokenCliente}}

{
  "valorSolicitadoCentavos": 500000,
  "quantidadeParcelas": 12,
  "taxaJurosMensal": 2.5
}

### Solicitar empréstimo
POST {{baseUrl}}/api/emprestimos
Content-Type: application/json
Authorization: Bearer {{tokenCliente}}

{
  "contaId": "{{contaClienteId}}",
  "valorSolicitadoCentavos": 500000,
  "quantidadeParcelas": 12,
  "taxaJurosMensal": 2.5
}

### Aprovar empréstimo
PATCH {{baseUrl}}/api/emprestimos/{{emprestimoId}}/aprovar
Authorization: Bearer {{tokenAdmin}}

### Pagar parcela 1
POST {{baseUrl}}/api/emprestimos/{{emprestimoId}}/parcelas/1/pagar
Authorization: Bearer {{tokenCliente}}

### Painel admin - resumo
GET {{baseUrl}}/api/admin/resumo
Authorization: Bearer {{tokenAdmin}}

### Painel admin - transações
GET {{baseUrl}}/api/admin/transacoes
Authorization: Bearer {{tokenAdmin}}
